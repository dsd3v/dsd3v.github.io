{
  "compilerOptions": {
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"]
    },
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES6",
    "lib": ["ES2017", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*"]
}
